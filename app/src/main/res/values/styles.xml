<resources>
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
        <item name="android:windowBackground">@color/nabd_bg</item>
        <item name="android:statusBarColor">@color/nabd_bg</item>
        <item name="android:navigationBarColor">@color/nabd_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/nabd_primary</item>
        <item name="colorOnPrimary">@color/nabd_on_primary</item>
        <item name="colorSecondary">@color/nabd_primary</item>
        <item name="colorOnSecondary">@color/nabd_on_primary</item>
        <item name="colorSurface">@color/nabd_surface</item>
        <item name="colorOnSurface">@color/nabd_on_surface</item>
        <item name="colorOutline">@color/nabd_outline</item>
        <item name="colorError">@color/nabd_error</item>
        <item name="materialAlertDialogTheme">@style/Nabd.MaterialAlertDialog</item>
        <item name="textInputStyle">@style/Nabd.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Nabd.MaterialButton</item>
    </style>

    <style name="Nabd.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/nabd_surface</item>
        <item name="colorOnSurface">@color/nabd_on_surface</item>
    </style>

    <style name="Nabd.MaterialButton" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Nabd.ComposerButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">22dp</item>
        <item name="backgroundTint">@color/nabd_outline</item>
        <item name="android:textColor">@color/nabd_on_surface</item>
    </style>

    <style name="Nabd.SendButton" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">22dp</item>
        <item name="backgroundTint">@color/nabd_primary</item>
        <item name="android:textColor">@color/nabd_on_primary</item>
    </style>

    <style name="Nabd.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/nabd_surface</item>
        <item name="boxStrokeColor">@color/nabd_outline</item>
        <item name="hintTextColor">@color/nabd_text_secondary</item>
        <item name="placeholderTextColor">@color/nabd_text_secondary</item>
        <item name="shapeAppearanceOverlay">@style/Nabd.ShapeAppearance.Medium</item>
    </style>

    <style name="Nabd.ShapeAppearance" parent="ShapeAppearance.Material3.Corner.None" />

    <style name="Nabd.ShapeAppearance.Medium" parent="Nabd.ShapeAppearance">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Nabd.ShapeAppearance.Large" parent="Nabd.ShapeAppearance">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>
