<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nabd_bg"
    android:gravity="top"
    android:layoutDirection="locale"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:text="نبض"
                android:textColor="@color/nabd_text"
                android:textDirection="locale"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subtitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="start"
                android:text="مساعد ذكاء اصطناعي محلي"
                android:textColor="@color/nabd_text_secondary"
                android:textDirection="locale"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/optionsButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="44dp"
            android:minHeight="44dp"
            android:text="الخيارات"
            android:textColor="@color/nabd_on_surface"
            android:textSize="14sp"
            app:backgroundTint="@color/nabd_surface"
            app:cornerRadius="16dp"
            app:strokeColor="@color/nabd_outline"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="start"
        android:textColor="@color/nabd_text_secondary"
        android:textDirection="locale"
        android:textSize="14sp" />

    <ScrollView
        android:id="@+id/chatScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <TextView
        android:id="@+id/tvTypingIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="start"
        android:text="نبض يكتب..."
        android:textColor="@color/nabd_text_secondary"
        android:textDirection="locale"
        android:textSize="14sp"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/sendProgressBar"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:indeterminateTint="@color/nabd_accent"
        android:visibility="gone" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/composerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:minHeight="56dp"
        app:cardBackgroundColor="@color/nabd_surface"
        app:cardCornerRadius="24dp"
        app:strokeColor="@color/nabd_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layoutDirection="ltr"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingTop="5dp"
            android:paddingEnd="6dp"
            android:paddingBottom="5dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAttachFile"
                style="@style/Nabd.ComposerButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:contentDescription="إضافة ملف"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="+"
                android:textColor="@color/nabd_on_surface"
                android:textSize="24sp"
                app:backgroundTint="@color/nabd_outline"
                app:iconPadding="0dp" />

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center_vertical|start"
                android:hint="اكتب ما يدور في بالك..."
                android:includeFontPadding="false"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="5"
                android:minHeight="44dp"
                android:minLines="1"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:singleLine="false"
                android:textAlignment="viewStart"
                android:textColor="@color/nabd_on_surface"
                android:textColorHint="@color/nabd_text_secondary"
                android:textDirection="locale"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSend"
                style="@style/Nabd.SendButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:contentDescription="إرسال النبض"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="↑"
                android:textColor="@color/nabd_on_primary"
                android:textSize="22sp"
                app:cornerRadius="22dp"
                app:backgroundTint="@color/nabd_primary"
                app:iconPadding="0dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
