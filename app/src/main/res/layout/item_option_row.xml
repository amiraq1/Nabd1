<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/optionRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_option_row"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:layoutDirection="locale"
    android:minHeight="52dp"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="8dp"
    android:paddingEnd="12dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/tvOptionIcon"
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:alpha="1.0"
        android:gravity="center"
        android:textColor="@color/nabd_text_secondary"
        android:textDirection="locale"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvOptionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="1.0"
            android:textColor="@color/nabd_on_surface"
            android:textDirection="locale"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvOptionSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:alpha="1.0"
            android:textColor="@color/nabd_text_secondary"
            android:textDirection="locale"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvOptionChevron"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:alpha="1.0"
        android:text="‹"
        android:textColor="#6A6A6A"
        android:textDirection="locale"
        android:textSize="20sp" />
</LinearLayout>
